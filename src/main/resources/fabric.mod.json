{
  "schemaVersion": 1,
  "id": "guishop",
  "version": "${version}",
  "name": "ClassicGUIShop",
  "description": "A server-side chest GUI shop with a built-in persistent economy, dynamic pricing, permissions, and administration commands.",
  "authors": ["Zycu", "Original GUIShop authors: _Waffles_ and AlreadyCoded"],
  "license": "All-Rights-Reserved",
  "environment": "*",
  "entrypoints": {
    "main": ["com.zycu.guishop.GuiShop"]
  },
  "depends": {
    "fabricloader": ">=0.18.4",
    "minecraft": "${minecraft_range}",
    "java": ">=25",
    "fabric-api": "*"
  },
  "suggests": {
    "fabric-permissions-api-v0": "*"
  }
}
